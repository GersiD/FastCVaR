@inproceedings{Ahmadi-Javid2011,
  title = {An Information-Theoretic Approach to Constructing Coherent Risk
           Measures},
  booktitle = {2011 {{IEEE International Symposium}} on {{Information Theory
               Proceedings}}},
  author = {{Ahmadi-Javid}, A.},
  year = {2011},
  month = jul,
  pages = {2125--2127},
  issn = {2157-8117},
  doi = {10.1109/ISIT.2011.6033932},
  urldate = {2025-01-02},
  abstract = {In the past decade, the new concept of coherent risk measure has
              found many applications in finance, insurance and operations
              research. In this paper, we introduce a new class of coherent risk
              measures constructed by using information-type pseudo-distances
              that generalize the Kullback-Leibler divergence, also known as the
              relative entropy. We first analyze the primal and dual
              representations of this class. We then study entropic value-at-risk
              (EVaR) which is the member of this class associated with relative
              entropy. We also show that conditional value-at-risk (CVaR), which
              is the most popular coherent risk measure, belongs to this class
              and is a lower bound for EVaR.},
  keywords = {Coherent risk measure,Conditional value-at-risk,Entropic
              value-at-risk,Entropy,Finance,Generalized relative entropy,
              Kullback-Leibler divergence,Operations research,Optimization,Q
              measurement,Random variables,Reactive power},
  file = {/home/marek/Zotero/storage/QDTU8M4B/Ahmadi-Javid - 2011 - An
          information-theoretic approach to constructing coherent risk
          measures.pdf;/home/marek/Zotero/storage/SABAXW5K/6033932.html},
}
@inproceedings{Petrik2024,
  title = {Bayesian {{Regret Minimization}} in {{Offline Bandits}}},
  booktitle = {Proceedings of the 41st {{International Conference}} on {{Machine Learning}}},
  author = {Petrik, Marek and Tennenholtz, Guy and Ghavamzadeh, Mohammad},
  year = {2024},
  month = jul,
  pages = {40502--40522},
  publisher = {PMLR},
  issn = {2640-3498},
  urldate = {2025-04-28},
  abstract = {We study how to make decisions that minimize Bayesian regret in offline linear bandits. Prior work suggests that one must take actions with maximum lower confidence bound (LCB) on their reward. We argue that reliance on LCB is inherently flawed in this setting and propose a new algorithm that directly minimizes upper-bounds on the Bayesian regret using efficient conic optimization solvers. Our bounds build heavily on new connections to monetary risk measures. Proving a matching lower-bound, we show that our upper-bounds are tight, and by minimizing them we are guaranteed to outperform the LCB approach. Our numerical results on synthetic domains confirm that our approach is superior to maximizing LCB.},
  copyright = {CC0 1.0 Universal Public Domain Dedication},
  langid = {english},
  file = {/home/marek/Zotero/storage/BGMLNBTT/Petrik et al. - 2024 - Bayesian Regret Minimization in Offline Bandits.pdf}
}


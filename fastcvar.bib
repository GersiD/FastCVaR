  issn = {1938-7228},
  urldate = {2024-09-11},
  abstract = {The problem of projecting onto the permutahedron {\textbackslash}mathbfPH(c) -- the convex hull of all permutations of a fixed vector c -- under a uniformly separable Bregman divergence is shown to be reducible to the Isotonic Optimization problem. This allows us to employ known fast algorithms to improve on several recent results on Bregman projections onto permutahedra. In addition, we present a new algorithm {\textbackslash}rm mergepool that have better complexity when the number of distinct entries d in the vector c is small, the simplex being one such example, with c=(1,0,0,{\textbackslash}dotsc,0){\textasciicircum}T and d=2. {\textbackslash}rm mergepool runs in O(n {\textbackslash}log d) for certain popular Bregman divergence measures and requires O((n {\textbackslash}log d) {\textbackslash}log {\textbackslash}fracU {$\varepsilon$}) to find {$\varepsilon$}-close solutions for general uniformly separable Bregman divergences, where U is a bound on the width of the interval containing the dual solution components. These estimates matches or improves best known bounds for all Bregman projection problems onto various permutahedra, including recent results for projection onto the simplex. The same complexity bounds apply to signed permutahedra, a class that includes the {\textbackslash}ell\_1-ball as a special case. In summary, this work describes a fast unified approach to this well-known class of problems.},
  langid = {english},
  file = {/home/marek/Zotero/storage/3HYNDR8J/lim16-supp.pdf;/home/marek/Zotero/storage/5XZJ9PBN/Lim and Wright - 2016 - Efficient Bregman Projections onto the Permutahedron and Related Polytopes.pdf}
